# Android
android/app/google-services.json

# iOS
ios/Runner/GoogleService-Info.plist

# Firebase CLI & emulator
.firebase/
firebase-debug.log
firestore-debug.log
ui-debug.log
.firebaserc          # contains project aliases — add back if not sensitive

# ─────────────────────────────────────────────
#  Android
# ─────────────────────────────────────────────
android/.gradle/
android/local.properties
android/key.properties          # signing keystore config  ⚠️ SENSITIVE
android/*.jks                   # keystore files           ⚠️ SENSITIVE
android/*.keystore
android/captures/
android/.idea/
android/gradlew
android/gradlew.bat
android/gradle/

