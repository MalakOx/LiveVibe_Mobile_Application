# ─────────────────────────────────────────────
#  Flutter / Dart
# ─────────────────────────────────────────────
# Build outputs
build/
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages

# Dart generated files
*.g.dart
*.freezed.dart
*.mocks.dart

# Pub cache & lock (keep pubspec.lock for reproducible builds)
# pubspec.lock   ← intentionally NOT ignored

# Coverage
coverage/

