rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Hosts can manage their own sessions
    match /sessions/{sessionId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.hostId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.hostId == request.auth.uid;
    }
    
    // Participants in a session can read/write their data
    match /sessions/{sessionId}/participants/{participantId} {
      allow read: if request.auth != null;
      allow create: if request.auth == null;  // Participants join without auth
      allow update, delete: if request.auth == null;  // Participant edits themselves
    }
    
    // Slides belong to sessions - read publicly (host can view), write by host only
    match /sessions/{sessionId}/slides/{slideId} {
      allow read: if request.auth != null;
      allow create, update, delete: if request.auth != null && 
        get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid;
    }
    
    // Responses are written by participants, read by host
    match /sessions/{sessionId}/responses/{responseId} {
      allow create: if request.auth == null;  // Participants submit responses
      allow read: if request.auth != null && 
        get(/databases/$(database)/documents/sessions/$(sessionId)).data.hostId == request.auth.uid;
    }
  }
}
